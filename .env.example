# Firebase Web App configuration. Copy to .env.local and fill in values.
# These VITE_-prefixed vars are inlined into the client bundle at build time.
# Web API keys are not secrets — security is enforced via Firestore Rules + App Check.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
